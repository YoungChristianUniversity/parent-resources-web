---
import type { Resource } from "../data/categories";

interface Props {
  resource: Resource;
}

const { resource } = Astro.props;

const topicLabels: Record<string, string> = {
  "faith & devotionals": "Spiritual Growth",
  "relationships & dating": "Relationships",
  "mental health": "Mental Health",
  "technology & screen time": "Technology",
  "character & values": "Character & Values",
  "college & career prep": "College & Career",
  "parenting skills": "Parenting Skills",
};
---

<article
  class="flex flex-col bg-surface-bright border border-outline-variant rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow duration-300"
  data-formats={JSON.stringify(resource.formats)}
  data-topics={JSON.stringify(resource.topics)}
>
  <!-- Image placeholder -->
  <div class="h-48 w-full bg-surface-container-high flex items-center justify-center">
    <span class="text-on-surface-variant/40 text-4xl font-serif font-bold select-none">
      {resource.name.charAt(0)}
    </span>
  </div>

  <div class="p-6 flex flex-col flex-1">
    <h4 class="text-headline-md font-serif font-semibold text-primary mb-2 line-clamp-2">
      {resource.name}
    </h4>
    <p class="text-body-md font-sans text-on-surface-variant mb-6 line-clamp-3 flex-1">
      {resource.description}
    </p>
    <div class="flex flex-wrap gap-2 mb-6 mt-auto">
      {resource.topics.map((topic) => (
        <span class="px-3 py-1 bg-surface-container-high text-on-surface-variant text-label-sm font-sans font-medium rounded-full">
          {topicLabels[topic] || topic}
        </span>
      ))}
    </div>
    <a
      href={resource.url}
      target="_blank"
      rel="noopener noreferrer"
      class="block w-full py-3 bg-secondary text-on-secondary rounded-lg font-sans font-semibold text-label-lg text-center hover:opacity-90 transition-opacity duration-200"
    >
      Visit Resource
    </a>
  </div>
</article>
