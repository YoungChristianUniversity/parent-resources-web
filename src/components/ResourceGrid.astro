---
import type { Resource } from "../data/categories";
import ResourceCard from "./ResourceCard.astro";

interface Props {
  resources: Resource[];
}

const { resources } = Astro.props;
---

<div class="flex-1 flex flex-col gap-8">
  <!-- Results count -->
  <div class="flex items-center">
    <p class="text-body-md font-sans text-on-surface-variant">
      Showing <span id="resource-count" class="font-semibold text-primary">{resources.length}</span> resources
    </p>
  </div>

  <!-- Grid -->
  <div id="resource-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
    {resources.map((resource) => (
      <ResourceCard resource={resource} />
    ))}
  </div>
</div>
