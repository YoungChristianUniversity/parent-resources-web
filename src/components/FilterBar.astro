---
import { formats, topics } from "../data/categories";

const formatLabels: Record<string, string> = {
  "book": "Books",
  "podcast": "Podcasts",
  "newsletter": "Newsletters",
  "website": "Websites",
  "app": "Apps",
  "video/course": "Videos & Courses",
};

const topicLabels: Record<string, string> = {
  "faith & devotionals": "Spiritual Growth",
  "relationships & dating": "Relationships",
  "mental health": "Mental Health",
  "technology & screen time": "Technology",
  "character & values": "Character & Values",
  "college & career prep": "College & Career",
  "parenting skills": "Parenting Skills",
};
---

<aside id="filter-bar" class="w-full md:w-64 flex-shrink-0">
  <div class="sticky top-[100px] flex flex-col gap-8">
    <div>
      <h2 class="text-headline-md font-serif font-bold text-primary mb-1">Refine By</h2>
    </div>

    <!-- Topics -->
    <div class="border-b border-outline-variant pb-6">
      <h3 class="text-label-lg font-sans font-semibold text-on-surface-variant mb-4 uppercase tracking-wider">Topics</h3>
      <ul class="flex flex-col gap-3">
        {topics.map((topic) => (
          <li>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input
                type="checkbox"
                class="filter-checkbox w-5 h-5 rounded border-outline-variant text-secondary focus:ring-secondary cursor-pointer"
                data-filter-type="topic"
                data-filter-value={topic}
              />
              <span class="text-body-md font-sans text-on-surface group-hover:text-secondary transition-colors">
                {topicLabels[topic] || topic}
              </span>
            </label>
          </li>
        ))}
      </ul>
    </div>

    <!-- Resource Type -->
    <div class="pb-6">
      <h3 class="text-label-lg font-sans font-semibold text-on-surface-variant mb-4 uppercase tracking-wider">Resource Type</h3>
      <ul class="flex flex-col gap-3">
        {formats.map((format) => (
          <li>
            <label class="flex items-center gap-3 cursor-pointer group">
              <input
                type="checkbox"
                class="filter-checkbox w-5 h-5 rounded border-outline-variant text-secondary focus:ring-secondary cursor-pointer"
                data-filter-type="format"
                data-filter-value={format}
              />
              <span class="text-body-md font-sans text-on-surface group-hover:text-secondary transition-colors">
                {formatLabels[format] || format}
              </span>
            </label>
          </li>
        ))}
      </ul>
    </div>
  </div>
</aside>
