---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ResourceGrid from "../components/ResourceGrid.astro";
import FilterBar from "../components/FilterBar.astro";
import Footer from "../components/Footer.astro";
import type { Resource } from "../data/categories";
import resourceData from "../data/resources.json";

const resources = resourceData as Resource[];
---

<Layout title="FaithParent — Faith-Based Resources for Parents of Teens">
  <Header />
  <Hero />
  <main class="w-full max-w-[1200px] mx-auto px-4 md:px-10 mt-16 md:mt-24 pb-16 flex flex-col md:flex-row gap-8 lg:gap-12">
    <FilterBar />
    <ResourceGrid resources={resources} />
  </main>
  <Footer />
</Layout>

<script>
  const filterBar = document.getElementById("filter-bar")!;
  const cards = document.querySelectorAll<HTMLElement>("#resource-grid > article");
  const countEl = document.getElementById("resource-count");

  const activeFilters: { format: Set<string>; topic: Set<string> } = {
    format: new Set(),
    topic: new Set(),
  };

  function filterCards() {
    let visibleCount = 0;
    cards.forEach((card) => {
      const cardFormats: string[] = JSON.parse(card.dataset.formats || "[]");
      const cardTopics: string[] = JSON.parse(card.dataset.topics || "[]");

      const matchesFormat =
        activeFilters.format.size === 0 ||
        cardFormats.some((f) => activeFilters.format.has(f));
      const matchesTopic =
        activeFilters.topic.size === 0 ||
        cardTopics.some((t) => activeFilters.topic.has(t));

      const visible = matchesFormat && matchesTopic;
      card.style.display = visible ? "" : "none";
      if (visible) visibleCount++;
    });

    if (countEl) countEl.textContent = String(visibleCount);
  }

  filterBar.addEventListener("change", (e) => {
    const checkbox = e.target as HTMLInputElement;
    if (!checkbox.classList.contains("filter-checkbox")) return;

    const type = checkbox.dataset.filterType as "format" | "topic";
    const value = checkbox.dataset.filterValue!;

    if (checkbox.checked) {
      activeFilters[type].add(value);
    } else {
      activeFilters[type].delete(value);
    }

    filterCards();
  });
</script>
